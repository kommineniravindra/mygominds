{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mygominds.com" }],
      "destination": "https://www.mygominds.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|webp|avif|svg|ico|css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}